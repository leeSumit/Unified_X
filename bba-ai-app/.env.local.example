# Anthropic Claude API key (required for module parsing and content generation)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API key (optional — used for OCR when parsing uploaded PDF/DOCX files)
# Without this key, only pasted text and plain .txt files are supported.
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Open Design integration (optional — enables "Open in Design Tool" button)
# Run Open Design first: cd open-design && pnpm tools-dev
# Daemon API port (default 7456): the bba-ai-app calls this to create projects
OPEN_DESIGN_DAEMON_URL=http://localhost:7456
# Web UI port (default 3000): the URL that opens in the browser
OPEN_DESIGN_WEB_URL=http://localhost:3000
