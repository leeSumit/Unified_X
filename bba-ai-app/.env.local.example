# Anthropic API key (required — Claude Haiku for parsing + Claude Sonnet for generation)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API key (optional — OCR when parsing uploaded PDF/DOCX files)
# Without this key, only pasted text and plain .txt files are supported.
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# fal.ai API key (optional — Flux.1 Schnell hero image generation in templates)
# Without this key, template previews work but show no hero image.
# Get yours at: https://fal.ai/
FAL_KEY=your_fal_key_here

# Open Design integration (optional — enables custom layout generation)
# Run Open Design first: cd open-design && pnpm tools-dev
# Update ports to match what tools-dev assigns at startup.
OPEN_DESIGN_DAEMON_URL=http://localhost:7456
OPEN_DESIGN_WEB_URL=http://localhost:3000
