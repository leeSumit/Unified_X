# Anthropic Claude API key (required for module parsing and content generation)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API key (optional — used for OCR when parsing uploaded PDF/DOCX files)
# Without this key, only pasted text and plain .txt files are supported.
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
